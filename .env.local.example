# Deploy-time values consumed client-side. See plan §9 for scope guidance.
#
# NOTE: Leave NEXT_PUBLIC_SITE_URL UNSET locally unless testing OG through a
# tunnel (ngrok, Cloudflare Tunnel). Locally it falls back to localhost:3000;
# on Vercel Preview it falls back to VERCEL_URL. Only set explicitly in Production.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# WhatsApp number in E.164 without the leading + (spaces are stripped at render time)
NEXT_PUBLIC_WHATSAPP_NUMBER=971585586265

# Mailto: fallback — from LinkedIn profile
NEXT_PUBLIC_CONTACT_EMAIL=mathieu.poissonnet@gmail.com

# Overrides the default in Nav / Footer / Hero if set
NEXT_PUBLIC_AGENT_NAME=Mathieu Poissonnet

# ─────────────────────────────────────────────────────────────
# Server-side email delivery for the contact form (Resend).
# Sign up at https://resend.com (free tier: 3,000 emails/mo).
# Without these, the form still validates and shows the thank-you
# screen — submissions are logged to the server console instead.
# ─────────────────────────────────────────────────────────────

# Your Resend API key — starts with "re_"
RESEND_API_KEY=

# Verified sender. Either your own domain (best deliverability) or
# Resend's shared onboarding@resend.dev for early testing.
CONTACT_FROM=Mathieu Poissonnet <no-reply@yourdomain.com>

# Where enquiries land
CONTACT_INBOX=mathieu.poissonnet@gmail.com
